# Telegram
BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=your_random_secret_for_webhook_validation

# Vercel
NEXT_PUBLIC_VERCEL_URL=https://your-project.vercel.app

# Railway
RAILWAY_API_URL=https://your-app.up.railway.app/run
RAILWAY_API_SECRET=your_secret_key_shared_with_railway

# Supabase (preferred)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Encryption (32-byte hex string). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key
